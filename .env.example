# Frontend (Vite) — estas se incluyen en el bundle del cliente.
# Usá SOLO la anon key acá, nunca la service_role key.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=tu_anon_key_aqui

# Imágenes satelitales Sentinel-2 + NDVI (Copernicus Data Space).
# Crear una configuración en https://shapps.dataspace.copernicus.eu/dashboard/
# con capas TRUE-COLOR y NDVI, y pegar acá su Instance ID.
VITE_SENTINEL_INSTANCE_ID=tu_instance_id_aqui

# Scripts admin de Node (crear-cliente.js) — NO usar prefijo VITE_,
# así nunca terminan en el bundle del frontend.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
